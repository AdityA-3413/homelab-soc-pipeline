# ============================================================
# AI-Driven Cyber Threat Detection — Environment Variables
# Author: Aditya Suresh Acharya
# ============================================================
# Copy this file to .env and fill in your own values
# NEVER commit your actual .env file to GitHub
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>

# --- InfluxDB ---
INFLUXDB_TOKEN=<YOUR_INFLUXDB_TOKEN>
INFLUXDB_PASSWORD=<YOUR_INFLUXDB_PASSWORD>
INFLUXDB_ORG=soc
INFLUXDB_BUCKET=wazuh_alerts

# --- Wazuh ---
WAZUH_API_PASSWORD=<YOUR_WAZUH_API_PASSWORD>
WAZUH_INDEXER_PASSWORD=<YOUR_INDEXER_PASSWORD>
WAZUH_DASHBOARD_PASSWORD=<YOUR_DASHBOARD_PASSWORD>

# --- n8n ---
N8N_BASIC_AUTH_PASSWORD=<YOUR_N8N_PASSWORD>

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=<YOUR_GRAFANA_PASSWORD>

# --- Server IPs (your Tailscale or local network IPs) ---
WAZUH_SERVER_IP=<YOUR_UBUNTU_VM_IP>
OLLAMA_HOST_IP=<YOUR_GPU_MACHINE_IP>
BLOCKER_PORT=9999
